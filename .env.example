# SchemeSeva independent runtime configuration

# Primary reasoning provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
SCHEMESEVA_SITE_URL=http://localhost:3000

# Primary embeddings provider
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Primary retrieval + memory
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=schemeseva_schemes
QDRANT_MEMORY_COLLECTION=schemeseva_memory
QDRANT_SESSIONS_COLLECTION=citizen_sessions
QDRANT_ALERTS_COLLECTION=pending_alerts
QDRANT_VECTOR_SIZE=768

# Primary safety validation
ENKRYPT_API_KEY=
ENKRYPT_BASE_URL=https://api.enkryptai.com

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local demo mode
NEXT_PUBLIC_DEMO_MODE=true
VITE_DEMO_MODE=true

# Optional fallback persistence/catalog only
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
