#### Privacy / Data Erasure — GDPR and DPDP Act 2023 Compliance

India's Digital Personal Data Protection Act 2023 (DPDP) and GDPR both require a right to erasure. Citizen session data stored in Qdrant is personal data and must be deleteable on request.

```typescript
// src/app/api/privacy/delete/route.ts
import { NextResponse } from 'next/server';
import { qdrant } from '../../../../lib/qdrant';

export async function DELETE(req: Request) {
  const { sessionId } = await req.json();

  if (!sessionId || typeof sessionId !== 'string') {
    return NextResponse.json({ error: 'sessionId required' }, { status: 400 });
  }

  try {
    // Delete citizen session from Qdrant
    await qdrant.delete('citizen_sessions', {
      wait: true,
      points: [sessionId],
    });

    // Delete any pending alerts for this session
    await qdrant.delete('pending_alerts', {
      wait: true,
      filter: {
        must: [{ key: 'sessionId', match: { value: sessionId } }],
      },
    });

    return NextResponse.json({
      deleted: true,
      message: 'All personal data associated with your session has been permanently deleted.',
      sessionId,
    });
  } catch (error) {
    return NextResponse.json(
      { error: 'Deletion failed — please try again', code: 500 },
      { status: 500 }
    );
  }
}
```

Add a "Delete my data" link in the UI footer:
```tsx
