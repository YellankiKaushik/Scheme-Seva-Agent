**Instrument the /api/discover route:**

```typescript
// src/app/api/discover/route.ts — add tracing
import { createTrace, langfuse } from '../../../lib/observability';

export async function POST(req: Request) {
  const { userInput, sessionId } = await req.json();
  const trace = createTrace('scheme-discovery', sessionId);

  // Span for Profile Agent
  const profileSpan = trace.span({ name: 'profile-agent', input: { userInput } });
  const profile = await runProfileAgent(userInput);
  profileSpan.end({ output: profile });

  // Span for Discovery Agent
  const discoverySpan = trace.span({ name: 'discovery-agent', input: profile });
  const candidates = await runDiscoveryAgent(profile);
  discoverySpan.end({ output: { count: candidates.length } });

  // Span for Eligibility Agent
  const eligSpan = trace.span({ name: 'eligibility-agent', input: { candidateCount: candidates.length } });
  const eligible = await runEligibilityAgent(profile, candidates);
  eligSpan.end({ output: { eligibleCount: eligible.length } });

  // Span for Report Agent
  const reportSpan = trace.span({ name: 'report-agent', input: { eligibleCount: eligible.length } });
  const report = await runReportAgent(eligible, profile);
  reportSpan.end({ output: { reportLength: report.length } });

  // Span for Enkrypt validation
  const enkryptSpan = trace.span({ name: 'enkrypt-safety', input: { contentLength: report.length } });
  const validation = await validateSchemeReport(report, eligible);
  enkryptSpan.end({ output: validation });

  await langfuse.flushAsync(); // Ensure trace is sent before response
  return NextResponse.json({ report, schemes: eligible, validated: validation.isSafe, sessionId });
}
```

**What you can see in the Langfuse dashboard:**
- Every agent step as a named span with input/output
- Token usage per agent (automatically captured when using OpenAI-compatible providers via OpenRouter)
- Latency per step — identify which agent is the bottleneck
- Error rates — which agent fails most often
- Cost tracking — how many tokens consumed per /api/discover call

